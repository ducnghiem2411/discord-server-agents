# Discord — 3 bots (create 3 applications at discord.com/developers)
MANAGER_BOT_TOKEN=your_manager_bot_token
MANAGER_BOT_CLIENT_ID=your_manager_application_client_id
DEV_BOT_TOKEN=your_dev_bot_token
DEV_BOT_CLIENT_ID=your_dev_application_client_id
QA_BOT_TOKEN=your_qa_bot_token
QA_BOT_CLIENT_ID=your_qa_application_client_id
DISCORD_GUILD_ID=your_discord_guild_id

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
POSTGRES_URL=postgresql://user:password@localhost:5432/discord_agents

# LLM Provider — set to: openai | anthropic | qwen
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Qwen (via OpenAI-compatible endpoint)
QWEN_API_KEY=sk-...
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# App
LOG_LEVEL=info
NODE_ENV=development
